APP_ENV=dev
PORT=3000

# Generate with: openssl rand -base64 32
COOKIE_SECRET=change-me

# Initial superadmin credentials (change before going to production)
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=superadmin

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vendure
DB_USERNAME=vendure
DB_PASSWORD=vendure
DB_SCHEMA=public

# Bridge para o middleware
MIDDLEWARE_URL=http://localhost:8080
# Secret compartilhado com o middleware — o plugin assina o JWT em runtime.
# Tem que ser IDÊNTICO ao JWT_SECRET do middleware/.env
JWT_SECRET=changeme-dev-token
